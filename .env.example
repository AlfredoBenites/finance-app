# Backend secrets — copy this file to .env.local and fill in real values.
# .env.local is gitignored; this .env.example is committed (names only, no values).

# Supabase API URL: https://<project-ref>.supabase.co  (NOT the dashboard URL)
SUPABASE_URL=

# Supabase key used by the backend.
# MVP: anon key (with RLS disabled). Production: service role key (with RLS enabled).
SUPABASE_KEY=

# Finnhub (free, no card) — stock quotes for the investments tracker.
# Get a key at finnhub.io. Crypto prices use CoinGecko (no key needed). Optional.
FINNHUB_API_KEY=

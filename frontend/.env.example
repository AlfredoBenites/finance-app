# Copy to .env.local.
# Base URL of the FastAPI backend. Use 127.0.0.1 (not "localhost") to force IPv4
# and avoid intermittent "Load failed" errors on macOS, where localhost can
# resolve to IPv6 first while uvicorn binds IPv4.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Supabase Auth (login/signup only). The anon key is a public key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
